# Desarrollo: SQLite. Producción: PostgreSQL (cambiar provider en prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

DEFAULT_MODEL=anthropic:claude-sonnet-4-5

# Auth.js v5 — generar con: openssl rand -base64 32
AUTH_SECRET=

# Seed del único super admin (npm run db:seed).
# Se obliga a cambiar la contraseña en el primer login.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Cifrado AES-256-GCM de las API keys guardadas en DB (panel admin).
# Generar con: openssl rand -base64 32  (ver DEPLOY.md)
APP_ENCRYPTION_KEY=
